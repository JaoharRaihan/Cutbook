rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(orgId) {
       return isAuthenticated() &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId == orgId &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner';
    }

    function isMember(orgId) {
       return isAuthenticated() &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId == orgId;
    }

    // Users
    match /users/{userId} {
      // Users can read/write their own profile
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      // Org members can read other members in same org (simplified for now)
      allow read: if isAuthenticated();
    }

    // Organizations
    match /organizations/{orgId} {
      allow create: if isAuthenticated();
      allow read: if isMember(orgId); // Only members see org details
      allow update: if isOwner(orgId) ||
        // Allow members to update cash fields (for accepting/rejecting payments)
        (isMember(orgId) &&
         request.resource.data.diff(resource.data).affectedKeys().hasAll(['mainCash', 'totalPayoutsGiven', 'updatedAt']) &&
         request.resource.data.diff(resource.data).affectedKeys().size() <= 3);

      // Allow joining via invite code query (handled via collection query rules mostly)
      // Since we query by inviteCode, we need list permission
      allow list: if isAuthenticated();
    }

    // Services
    match /services/{serviceId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(resource.data.orgId) || isOwner(request.resource.data.orgId);
    }

    // Work Entries
    match /workEntries/{entryId} {
      allow read: if isMember(resource.data.orgId);
      allow create: if isMember(request.resource.data.orgId);
      // Only creator or owner can update/delete?
      allow update, delete: if isMember(resource.data.orgId);
    }

    // Daily Summaries
    match /dailySummaries/{summaryId} {
      allow read: if isMember(resource.data.orgId);
      allow write: if isMember(resource.data.orgId); // Usually server-side or triggered by clients
    }

    // Employee Transactions (Owner → Employee Payments)
    match /employeeTransactions/{transactionId} {
      // Employees can read their own transactions + all org transactions (to see who sent them)
      allow read: if isMember(resource.data.orgId);
      // Only the owner of the org can create transactions
      allow create: if isOwner(request.resource.data.orgId);
      // Employees can update their response (status, respondedAt, respondedBy)
      // Owners can update any transaction in their org
      allow update: if isMember(resource.data.orgId) &&
        (
          // Employee responding to transaction (only update status/respondedAt/respondedBy)
          (resource.data.employeeId == request.auth.uid &&
           request.resource.data.employeeId == resource.data.employeeId &&
           request.resource.data.amount == resource.data.amount) ||
          // Owner managing transaction
          isOwner(resource.data.orgId)
        );
      // Only owner can delete
      allow delete: if isOwner(resource.data.orgId);
    }

    // Notifications (Payment request / accepted / rejected)
    match /notifications/{notificationId} {
      // Recipients can read their own notifications
      allow read: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
      // Any authenticated user can create notifications (sender creates for recipient)
      allow create: if isAuthenticated();
      // Recipients can update their own notifications (mark as read)
      allow update: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
      // Recipients can delete their own notifications
      allow delete: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
    }

    // OTP Verification codes (Unauthenticated allowed for registration and forgot password)
    match /otps/{otpId} {
      allow create: if true;
      allow read, update: if true;
    }

    // Password Reset Requests
    match /passwordResetRequests/{requestId} {
      allow create: if true;
      allow read: if isAuthenticated();
    }
  }
}
